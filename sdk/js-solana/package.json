{
  "bugs": {
    "url": "https://github.com/pyth-network/pyth-crosschain/issues"
  },
  "dependencies": {
    "@solana/buffer-layout": "catalog:",
    "@solana/web3.js": "catalog:"
  },
  "description": "Pyth Lazer Solana SDK",
  "devDependencies": {
    "@cprussin/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "typedoc": "catalog:"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "default": "./dist/esm/index.mjs",
        "types": "./dist/esm/index.d.ts"
      },
      "require": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.ts"
      }
    },
    "./ed25519": {
      "import": {
        "default": "./dist/esm/ed25519.mjs",
        "types": "./dist/esm/ed25519.d.ts"
      },
      "require": {
        "default": "./dist/cjs/ed25519.cjs",
        "types": "./dist/cjs/ed25519.d.ts"
      }
    },
    "./idl/pyth-lazer-solana-contract": {
      "import": {
        "default": "./dist/esm/idl/pyth-lazer-solana-contract.mjs",
        "types": "./dist/esm/idl/pyth-lazer-solana-contract.d.ts"
      },
      "require": {
        "default": "./dist/cjs/idl/pyth-lazer-solana-contract.cjs",
        "types": "./dist/cjs/idl/pyth-lazer-solana-contract.d.ts"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "homepage": "https://github.com/pyth-network/pyth-crosschain/tree/main/lazer/sdk/js-solana",
  "keywords": [
    "pyth",
    "oracle"
  ],
  "license": "Apache-2.0",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "name": "@pythnetwork/pyth-lazer-solana-sdk",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "lazer/sdk/js-solana",
    "type": "git",
    "url": "https://github.com/pyth-network/pyth-crosschain"
  },
  "scripts": {
    "build": "ts-duality",
    "build:docs": "typedoc --out docs/typedoc src",
    "clean": "rm -rf ./dist",
    "test:types": "tsc --noEmit --project ./tsconfig.build.json",
    "update-idl": "cd ../../contracts/solana && RUSTUP_TOOLCHAIN=nightly-2025-04-15 anchor build && cp target/types/pyth_lazer_solana_contract.ts ../../sdk/js-solana/src/idl/pyth-lazer-solana-contract.ts && cp target/idl/pyth_lazer_solana_contract.json ../../sdk/js-solana/src/idl/pyth-lazer-solana-contract.json"
  },
  "type": "module",
  "types": "./dist/cjs/index.d.ts",
  "version": "0.2.0"
}
