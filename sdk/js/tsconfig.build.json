{
  "compilerOptions": {
    "declaration": true,
    "incremental": false,
    "isolatedModules": false,
    "noEmit": false,
    "outDir": "./dist"
  },
  "exclude": [
    "node_modules",
    "examples",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__"
  ],
  "extends": "./tsconfig.json"
}
