  "name": "@pythnetwork/pyth-lazer",
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "dep:check": "bun outdated -r '!@types/*'",
    "dep:check:all": "bun outdated -r",
    "fix:lint": "biome check --max-diagnostics=none --write",
    "fix:lint:changed": "bun run fix:lint --changed",
    "fix:lint:staged": "bun run fix:lint --staged",
    "install:modules": "[ $CI ] && true || bun install",
    "start:dev:pyth-app": "turbo run start:dev --filter ./apps/pyth-app",
    "test:lint": "biome check --max-diagnostics=none --no-errors-on-unmatched",
    "test:lint:changed": "biome check --max-diagnostics=none --changed --no-errors-on-unmatched",
    "test:lint:staged": "biome check --max-diagnostics=none --staged --no-errors-on-unmatched",
    "turbo": "[ ! -d node_modules ] && bun install; turbo"
  },
