{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "API_KEY_HUBSPOT",
    "API_KEY_RESEND",
    "API_KEY_STRIPE",
    "AUTH_BASE_URL",
    "BETTER_AUTH_SECRET",
    "BILLING_ENABLED",
    "CLICKHOUSE_PYTH_ANALYTICS_PASSWORD",
    "CLICKHOUSE_PYTH_ANALYTICS_URL",
    "CLICKHOUSE_PYTH_ANALYTICS_USERNAME",
    "CLICKHOUSE_PYTH_PRO_PASSWORD",
    "CLICKHOUSE_PYTH_PRO_URL",
    "CLICKHOUSE_PYTH_PRO_USERNAME",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DOUROLABS_DOMAIN",
    "DOURO_LABS_ONLY",
    "EMAIL_ALWAYS_SEND",
    "EMAIL_NOREPLY_ADDRESS",
    "FREE_PRICE_ID",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "HUBSPOT_CONTACT_SALES_FORM_ID",
    "HUBSPOT_FORMS_BASE_URL",
    "HUBSPOT_MARKETING_SUBSCRIPTION_ID",
    "HUBSPOT_PORTAL_ID",
    "LAZER_API_BASE_URL",
    "LAZER_HISTORY_TOKEN",
    "LOGIN_ENABLED",
    "MAGIC_LINK_DURATION",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "NEON_API_KEY",
    "NEXT_PUBLIC_API_BASE",
    "NEXT_PUBLIC_DOURO_LABS_ONLY",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_PYTH_DEVELOPER_HUB_URL",
    "NEON_PYTH_PRO_URL",
    "POSTHOG_API_KEY",
    "POSTHOG_HOST",
    "POSTHOG_PROJECT_ID",
    "NODE_ENV",
    "PYTH_DEVELOPER_HUB_URL",
    "RESTRICTED_COUNTRIES",
    "RESTRICTED_UKRAINIAN_REGIONS",
    "SELECTABLE_PRICE_IDS",
    "SIGNUP_ENABLED",
    "STRIPE_MAX_NETWORK_RETRIES",
    "SYMBOLS_CACHE_ENABLED",
    "TRIAL_PERIOD_DAYS",
    "TRIAL_PRICE_ID",
    "SOCIAL_PROVIDERS",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_ENV_OVERRIDE",
    "WORDMARK_URL"
  ],
  "globalPassThroughEnv": [
    "AUTH_TOKENS",
    "CLICKHOUSE_USERNAME",
    "CLICKHOUSE_PASSWORD",
    "CLICKHOUSE_HOST",
    "FORCE_COLOR",
    "BIOME_BINARY"
  ],
  "tasks": {
    "//#fix:format": {
      "cache": false,
      "dependsOn": ["//#install:modules", "//#fix:lint"]
    },
    "//#fix:lint": {
      "cache": false,
      "dependsOn": ["//#install:modules", "^build"]
    },
    "//#install:modules": {
      "inputs": [
        "**/package.json",
        ".npmrc",
        ".npmignore",
        "bunfig.toml",
        "!**/.next/**",
        "!**/dist/**"
      ],
      "outputs": ["bun.lock"]
    },
    "//#test": {
      "dependsOn": [
        "//#test:types",
        "//#test:unit",
        "//#test:integration",
        "//#test:lint"
      ]
    },
    "//#test:integration": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "//#test:lint": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "//#test:lint:changed": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "//#test:lint:staged": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "//#test:types": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "//#test:unit": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "auth:db:migrate": {
      "cache": false,
      "dependsOn": ["setup:neon-branch"]
    },
    "build": {
      "dependsOn": [
        "//#install:modules",
        "pull:env",
        "clean",
        "^build",
        "test:types"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!**/*.test.*",
        "!jest.config.js",
        "!eslint.config.js",
        "!biome.json",
        "!vercel.json"
      ],
      "outputs": ["lib/**", "dist/**", ".next/**", "!.next/cache/**"]
    },
    "build:storybook": {
      "inputs": ["src/**", ".storybook/**", "package.json", "bun.lock"],
      "outputs": ["storybook-static/**"]
    },
    "build:vercel": {
      "dependsOn": [
        "//#install:modules",
        "auth:db:migrate",
        "^build",
        "test:types"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!**/*.test.*",
        "!jest.config.js",
        "!eslint.config.js",
        "!vercel.json"
      ],
      "outputs": ["lib/**", "dist/**", ".next/**", "!.next/cache/**"]
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "fix:lint": {
      "cache": false,
      "dependsOn": ["//#install:modules", "^build"]
    },
    "fix:lint:changed": {
      "cache": false,
      "dependsOn": ["^build", "^fix:lint:staged"]
    },
    "fix:lint:staged": {
      "cache": false,
      "dependsOn": ["^build", "^fix:lint:staged"]
    },
    "pull:env": {
      "cache": false,
      "dependsOn": ["//#install:modules"],
      "outputs": [".env.local"]
    },
    "setup:neon-branch": {
      "cache": false,
      "dependsOn": ["pull:env"],
      "outputs": [".env.local"]
    },
    "start:dev": {
      "cache": false,
      "dependsOn": ["//#install:modules", "auth:db:migrate", "^build"],
      "persistent": true
    },
    "start:prod": {
      "cache": false,
      "dependsOn": ["//#install:modules", "build"],
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "with": ["test:types", "test:unit", "test:integration", "//#test:lint"]
    },
    "test:changed": {
      "dependsOn": ["^build", "//#test:lint:changed", "test:types"]
    },
    "test:ci": {
      "dependsOn": [
        "test:types",
        "test:unit",
        "test:integration",
        "//#test:lint:changed"
      ]
    },
    "test:integration": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "test:lint": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "test:staged": {
      "dependsOn": ["^build", "//#test:lint:staged", "test:types"]
    },
    "test:types": {
      "dependsOn": ["//#install:modules", "^build"]
    },
    "test:unit": {
      "dependsOn": ["//#install:modules", "^build"]
    }
  },
  "ui": "tui"
}
